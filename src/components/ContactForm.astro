---
import type { ParsedContactSettings } from '@/types/cms';

interface Props {
  contact: Pick<
    ParsedContactSettings,
    | 'formspreeEndpoint'
    | 'categoryOptions'
    | 'planOptions'
    | 'budgetOptions'
    | 'submitButtonText'
    | 'replyTime'
  >;
}

const { contact } = Astro.props;
const hasEndpoint = Boolean(contact.formspreeEndpoint);
const submitLabel = hasEndpoint ? contact.submitButtonText : 'フォーム準備中';
---

<form
  class="contact-form"
  id="contact-form"
  action={contact.formspreeEndpoint}
  method="post"
  data-has-endpoint={hasEndpoint ? 'true' : 'false'}
  data-submit-label={contact.submitButtonText}
  novalidate
>
  <div class="contact-form__status contact-form__status--success" role="status" hidden>
    <p class="contact-form__status-title">送信が完了しました</p>
    <p class="contact-form__status-desc">
      お問い合わせありがとうございます。内容を確認のうえ、{contact.replyTime}
    </p>
  </div>

  <div class="contact-form__status contact-form__status--error" role="alert" hidden>
    <p class="contact-form__status-title">送信に失敗しました</p>
    <p class="contact-form__status-desc" data-error-message>
      時間をおいて再度お試しください。解決しない場合はメールでご連絡ください。
    </p>
  </div>

  <div class="contact-form__fields" data-form-fields>
    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-name">
        お名前 <span class="contact-form__required">必須</span>
      </label>
      <input
        class="contact-form__input"
        type="text"
        id="contact-name"
        name="name"
        autocomplete="name"
        required
        placeholder="山田 太郎"
      />
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-company">会社名・屋号</label>
      <input
        class="contact-form__input"
        type="text"
        id="contact-company"
        name="company"
        autocomplete="organization"
        placeholder="株式会社〇〇 / 〇〇カフェ"
      />
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-email">
        メールアドレス <span class="contact-form__required">必須</span>
      </label>
      <input
        class="contact-form__input"
        type="email"
        id="contact-email"
        name="email"
        autocomplete="email"
        inputmode="email"
        required
        placeholder="example@email.com"
      />
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-category">ご相談内容カテゴリ</label>
      <select class="contact-form__select" id="contact-category" name="category">
        <option value="">選択してください</option>
        {contact.categoryOptions.map((option) => (
          <option value={option}>{option}</option>
        ))}
      </select>
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-plan">希望プラン</label>
      <select class="contact-form__select" id="contact-plan" name="plan">
        <option value="">選択してください</option>
        {contact.planOptions.map((option) => (
          <option value={option}>{option}</option>
        ))}
      </select>
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-budget">ご予算</label>
      <select class="contact-form__select" id="contact-budget" name="budget">
        <option value="">選択してください</option>
        {contact.budgetOptions.map((option) => (
          <option value={option}>{option}</option>
        ))}
      </select>
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-reference-url">参考サイトURL</label>
      <input
        class="contact-form__input"
        type="url"
        id="contact-reference-url"
        name="referenceUrl"
        inputmode="url"
        autocomplete="url"
        placeholder="https://example.com"
      />
    </div>

    <div class="contact-form__field">
      <label class="contact-form__label" for="contact-message">
        お問い合わせ内容 <span class="contact-form__required">必須</span>
      </label>
      <textarea
        class="contact-form__textarea"
        id="contact-message"
        name="message"
        rows="7"
        required
        placeholder="ご相談内容、ご希望のスケジュールなどをご記入ください。"
      ></textarea>
    </div>

    <input type="text" name="_gotcha" class="contact-form__honeypot" tabindex="-1" autocomplete="off" />

    <div class="contact-form__field contact-form__field--consent">
      <label class="contact-form__consent">
        <input
          class="contact-form__checkbox"
          type="checkbox"
          id="contact-consent"
          name="consent"
          value="yes"
          required
        />
        <span class="contact-form__consent-text">
          <a href="/privacy/" target="_blank" rel="noopener noreferrer">プライバシーポリシー</a>
          に同意のうえ送信する <span class="contact-form__required">必須</span>
        </span>
      </label>
    </div>

    <button
      class="btn btn--primary btn--lg btn--block contact-form__submit"
      type="submit"
      disabled={!hasEndpoint}
    >
      {submitLabel}
    </button>
  </div>
</form>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    const fields = form.querySelector('[data-form-fields]') as HTMLElement | null;
    const success = form.querySelector('.contact-form__status--success') as HTMLElement | null;
    const error = form.querySelector('.contact-form__status--error') as HTMLElement | null;
    const errorMessage = form.querySelector('[data-error-message]') as HTMLElement | null;
    const submitBtn = form.querySelector('.contact-form__submit') as HTMLButtonElement | null;
    const hasEndpoint = form.dataset.hasEndpoint === 'true';
    const submitLabel = form.dataset.submitLabel ?? '送信する';

    const showStatus = (type: 'success' | 'error', message?: string) => {
      success?.toggleAttribute('hidden', type !== 'success');
      error?.toggleAttribute('hidden', type !== 'error');
      fields?.toggleAttribute('hidden', type === 'success');
      if (message && errorMessage) errorMessage.textContent = message;
    };

    form.addEventListener('submit', async (event) => {
      if (!hasEndpoint) {
        event.preventDefault();
        return;
      }

      event.preventDefault();

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const honeypot = form.querySelector<HTMLInputElement>('input[name="_gotcha"]');
      if (honeypot?.value) return;

      submitBtn?.setAttribute('disabled', 'true');
      if (submitBtn) submitBtn.textContent = '送信中…';
      error?.setAttribute('hidden', '');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });

        if (!response.ok) {
          const data = (await response.json().catch(() => null)) as { error?: string } | null;
          throw new Error(data?.error ?? '送信に失敗しました');
        }

        form.reset();
        showStatus('success');
        success?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } catch (err) {
        const message =
          err instanceof Error ? err.message : '送信に失敗しました。時間をおいて再度お試しください。';
        showStatus('error', message);
      } finally {
        if (hasEndpoint) {
          submitBtn?.removeAttribute('disabled');
          if (submitBtn) submitBtn.textContent = submitLabel;
        }
      }
    });
  }
</script>

<style>
  .contact-form {
    padding: var(--space-lg);
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
  }

  .contact-form__fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-form__field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form__label {
    font-size: var(--text-small);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text);
  }

  .contact-form__required {
    font-size: var(--text-caption);
    color: var(--color-gold);
    letter-spacing: 0.08em;
    margin-left: 0.25rem;
  }

  .contact-form__input,
  .contact-form__select,
  .contact-form__textarea {
    width: 100%;
    min-height: 3rem;
    padding: 0.75rem 0.875rem;
    font-family: var(--font-serif);
    font-size: var(--text-body);
    color: var(--color-text);
    background-color: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: 0;
    line-height: 1.5;
    transition: border-color var(--transition);
  }

  .contact-form__input::placeholder,
  .contact-form__textarea::placeholder {
    color: var(--color-text-light);
  }

  .contact-form__input:focus,
  .contact-form__select:focus,
  .contact-form__textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 1px var(--color-gold-soft);
  }

  .contact-form__textarea {
    resize: vertical;
    min-height: 9rem;
  }

  .contact-form__honeypot {
    display: none;
  }

  .contact-form__field--consent {
    margin-top: var(--space-xs);
  }

  .contact-form__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    cursor: pointer;
  }

  .contact-form__checkbox {
    flex-shrink: 0;
    width: 1rem;
    height: 1rem;
    margin-top: 0.2rem;
    accent-color: var(--color-gold);
  }

  .contact-form__consent-text {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .contact-form__consent-text a {
    color: var(--color-accent-dark);
    text-decoration: underline;
    transition: color var(--transition);
  }

  .contact-form__consent-text a:hover {
    color: var(--color-text);
  }

  .contact-form__submit {
    margin-top: var(--space-xs);
  }

  .contact-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .contact-form__status {
    padding: var(--space-md);
    border: 1px solid var(--color-border-light);
  }

  .contact-form__status--success {
    background-color: var(--color-bg-accent);
  }

  .contact-form__status--error {
    background-color: #faf7f0;
    border-color: #ddd5c7;
  }

  .contact-form__status-title {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    font-weight: 500;
    margin-bottom: 0.375rem;
    color: var(--color-text);
  }

  .contact-form__status-desc {
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
  }
</style>
