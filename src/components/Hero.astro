---
import Button from '@/components/Button.astro';
import type { SiteSettings } from '@/types/cms';

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
---

<section class="hero">
  <div class="hero__wash" aria-hidden="true"></div>

  <div class="hero__inner container">
    <header class="hero__brand">
      <p class="hero__eyebrow label-en">
        {settings.location} — Web Production Studio
      </p>

      <h1 class="hero__display" aria-label={settings.brandDisplay}>
        <span class="hero__display-line">{settings.logoText}</span>
      </h1>

      <div class="hero__meta">
        <p class="hero__studio label-en">Web Studio</p>
        <div class="hero__rule" aria-hidden="true"></div>
      </div>
    </header>

    <div class="hero__content">
      <p class="hero__catch cms-text">{settings.catchCopy}</p>

      <div class="hero__copy">
        <p class="hero__desc cms-text">{settings.heroDescription}</p>
        <p class="hero__note">個人店・小規模事業者の方も、お気軽にご相談ください。</p>
      </div>

      <div class="hero__actions">
        <Button href="/plans/" variant="primary" size="lg">本格制作プランを見る</Button>
        <Button href="/works/" variant="text" size="lg">実績を見る</Button>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    display: flex;
    align-items: flex-end;
    padding-bottom: clamp(3rem, 8vw, 5rem);
    overflow: hidden;
  }

  .hero__wash {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 80% 60% at 85% 15%, rgba(229, 217, 197, 0.45) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 10% 80%, rgba(244, 240, 233, 0.8) 0%, transparent 50%);
  }

  .hero__inner {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 5vw, 2.5rem);
    padding-top: clamp(3rem, 10vw, 6rem);
  }

  .hero__eyebrow {
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }

  .hero__display {
    margin-bottom: clamp(1rem, 3vw, 1.75rem);
  }

  .hero__display-line {
    display: block;
    font-family: var(--font-serif);
    font-size: var(--text-display);
    font-weight: 500;
    line-height: 0.95;
    letter-spacing: 0.12em;
    color: var(--color-text);
  }

  .hero__meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .hero__rule {
    flex: 1;
    max-width: 120px;
    height: 1px;
    background-color: var(--color-accent);
    opacity: 0.6;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .hero__catch {
    font-family: var(--font-serif);
    font-size: var(--text-subheading);
    font-weight: 500;
    line-height: var(--leading-snug);
    letter-spacing: 0.04em;
    color: var(--color-text);
    max-width: 18em;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .hero__desc {
    font-size: 1.0625rem;
    color: var(--color-text);
    line-height: 1.9;
    max-width: 32em;
  }

  .hero__note {
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-accent-dark);
    line-height: var(--leading-body);
  }

  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    margin-top: var(--space-sm);
  }

  @media (min-width: 480px) {
    .hero__actions {
      flex-direction: row;
      align-items: center;
      gap: var(--space-xl);
    }
  }

  @media (min-width: 900px) {
    .hero {
      align-items: center;
      padding-block: clamp(3rem, 8vh, 5rem);
    }

    .hero__wash {
      background:
        radial-gradient(ellipse 55% 45% at 75% 20%, rgba(229, 217, 197, 0.35) 0%, transparent 65%),
        radial-gradient(ellipse 35% 30% at 15% 75%, rgba(244, 240, 233, 0.55) 0%, transparent 55%);
    }

    .hero__inner {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      gap: clamp(3rem, 6vw, 5.5rem);
      align-items: end;
      padding-top: 0;
      max-width: var(--container-wide);
    }

    .hero__brand {
      padding-bottom: 0.25rem;
    }

    .hero__eyebrow {
      margin-bottom: var(--space-xl);
    }

    .hero__display {
      margin-bottom: var(--space-lg);
    }

    .hero__display-line {
      font-size: clamp(3.25rem, 5vw, 4.5rem);
      letter-spacing: 0.1em;
      line-height: 1.05;
    }

    .hero__meta {
      display: none;
    }

    .hero__content {
      gap: var(--space-lg);
      padding-bottom: 0.35rem;
      border-left: 1px solid var(--color-accent-light);
      padding-left: clamp(2rem, 4vw, 3rem);
    }

    .hero__catch {
      font-size: clamp(1.25rem, 1.8vw, 1.4375rem);
      max-width: none;
      line-height: var(--leading-snug);
    }

    .hero__desc,
    .hero__note {
      max-width: none;
    }

    .hero__actions {
      margin-top: var(--space-md);
    }
  }

  @media (min-width: 1200px) {
    .hero__inner {
      gap: 6rem;
    }

    .hero__display-line {
      font-size: 4.75rem;
    }
  }
</style>
