---
import { formatNewsDate } from '@/lib/news';
import { NEWS_CATEGORY_LABELS } from '@/types/cms';
import type { NewsItem } from '@/types/cms';

interface Props {
  items: NewsItem[];
}

const { items } = Astro.props;

const newsDataMap = Object.fromEntries(
  items.map((item) => [
    item.id,
    {
      title: item.title,
      body: item.body,
      date: formatNewsDate(item.date),
      dateIso: item.date,
      category: NEWS_CATEGORY_LABELS[item.category],
    },
  ]),
);
---

<div
  class="modal-overlay modal-overlay--news"
  id="news-modal"
  aria-hidden="true"
  role="dialog"
  aria-modal="true"
  aria-labelledby="news-modal-title"
>
  <div class="modal modal--news" data-news-panel>
    <div class="news-modal__paper" aria-hidden="true">
      <span class="news-modal__fiber"></span>
    </div>
    <div class="news-modal__accent" aria-hidden="true"></div>

    <div class="modal__header news-modal__header">
      <div class="news-modal__head">
        <div class="news-modal__eyebrow">
          <p class="news-modal__label label-en">News</p>
          <span class="news-modal__category" id="news-modal-category"></span>
        </div>
        <h2 class="modal__title news-modal__title" id="news-modal-title"></h2>
        <time class="news-modal__date" id="news-modal-date" datetime=""></time>
      </div>
      <button class="modal__close news-modal__close" type="button" aria-label="閉じる" data-news-close>
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M5 5L15 15M15 5L5 15" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="modal__body news-modal__body" id="news-modal-body"></div>
  </div>
</div>

<script define:vars={{ newsDataMap }}>
  const modal = document.getElementById('news-modal');
  const modalTitle = document.getElementById('news-modal-title');
  const modalDate = document.getElementById('news-modal-date');
  const modalCategory = document.getElementById('news-modal-category');
  const modalBody = document.getElementById('news-modal-body');
  const closeBtn = modal?.querySelector('[data-news-close]');

  function isOpen() {
    return modal?.classList.contains('is-open') ?? false;
  }

  function openModal(news) {
    if (!modal || !modalTitle || !modalDate || !modalCategory || !modalBody) return;

    modalTitle.textContent = news.title;
    modalDate.textContent = news.date;
    modalDate.setAttribute('datetime', news.dateIso);
    modalCategory.textContent = news.category;

    modalBody.replaceChildren();
    const body = document.createElement('p');
    body.className = 'cms-text';
    body.textContent = news.body;
    modalBody.appendChild(body);

    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('is-modal-open');
    modalBody.scrollTop = 0;
    closeBtn?.focus();
  }

  function closeModal() {
    if (!modal || !isOpen()) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('is-modal-open');
  }

  if (!window.__newsModalBound) {
    window.__newsModalBound = true;

    document.addEventListener('click', (e) => {
      const target = e.target;
      if (!(target instanceof Element)) return;

      const openBtn = target.closest('[data-news-open]');
      if (openBtn) {
        e.preventDefault();
        const id = openBtn.getAttribute('data-news-id');
        if (id && newsDataMap[id]) {
          openModal(newsDataMap[id]);
        }
        return;
      }

      if (target.closest('[data-news-close]')) {
        closeModal();
        return;
      }

      if (target === modal) {
        closeModal();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen()) {
        closeModal();
      }
    });
  }
</script>

<style is:global>
  .modal-overlay.modal-overlay--news {
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    background:
      radial-gradient(ellipse 70% 55% at 50% 42%, rgba(42, 36, 28, 0.28) 0%, transparent 72%),
      rgba(24, 21, 18, 0.52);
  }

  .modal-overlay.modal-overlay--news .modal.modal--news {
    position: relative;
    isolation: isolate;
    width: 100%;
    max-width: min(48rem, calc(100vw - 2.5rem));
    max-height: min(84vh, 40rem);
    background-color: #f2eadc;
    border: 1px solid rgba(168, 150, 122, 0.28);
    box-shadow:
      0 0.15rem 0.35rem rgba(48, 38, 24, 0.06),
      0 0.75rem 1.75rem rgba(48, 38, 24, 0.1),
      0 1.75rem 3.5rem rgba(28, 22, 14, 0.14),
      inset 0 1px 0 rgba(255, 252, 246, 0.65),
      inset 0 -1.25rem 2.5rem rgba(196, 170, 120, 0.06);
    transform: translateY(0.875rem);
    opacity: 0;
    transition:
      transform 0.36s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.28s ease;
  }

  .modal-overlay.modal-overlay--news.is-open .modal.modal--news {
    transform: translateY(0);
    opacity: 1;
  }

  .news-modal__paper {
    pointer-events: none;
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .news-modal__paper::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(168deg, #f8f2e6 0%, #f1e8d6 38%, #ebe1cd 72%, #e7dcc6 100%),
      radial-gradient(ellipse 90% 70% at 12% 8%, var(--washi-bright) 0%, transparent 55%),
      radial-gradient(ellipse 70% 55% at 88% 92%, rgba(214, 194, 158, 0.22) 0%, transparent 60%);
  }

  .news-modal__fiber {
    position: absolute;
    inset: 0;
    opacity: 0.55;
    background-image:
      url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3CfeColorMatrix values='0 0 0 0 0.72 0 0 0 0 0.64 0 0 0 0 0.48 0 0 0 0.55 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    mix-blend-mode: multiply;
  }

  .news-modal__accent {
    position: absolute;
    top: 0;
    left: 1.75rem;
    right: 1.75rem;
    z-index: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--color-gold-line-soft) 12%,
      var(--color-gold-line) 50%,
      var(--color-gold-line-soft) 88%,
      transparent 100%
    );
  }

  .news-modal__header {
    position: relative;
    z-index: 1;
    align-items: flex-start;
    gap: var(--space-sm);
    padding: 2rem 2rem 1.25rem;
    background: transparent;
    border-bottom: none;
  }

  .news-modal__head {
    flex: 1;
    min-width: 0;
    padding-right: 0.25rem;
  }

  .news-modal__eyebrow {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem 0.875rem;
    margin-bottom: 1rem;
  }

  .news-modal__label {
    margin: 0;
    color: rgba(131, 123, 110, 0.9);
  }

  .news-modal__category {
    font-size: var(--text-caption);
    letter-spacing: 0.14em;
    color: var(--color-gold);
  }

  .news-modal__title {
    margin: 0 0 0.875rem;
    font-size: clamp(1.25rem, 2.5vw, 1.4375rem);
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }

  .news-modal__date {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.16em;
    color: rgba(131, 123, 110, 0.85);
  }

  .news-modal__close {
    width: 2rem;
    height: 2rem;
    margin-top: -0.125rem;
    margin-right: -0.35rem;
    color: rgba(131, 123, 110, 0.72);
  }

  .news-modal__close:hover {
    color: var(--color-text);
  }

  .news-modal__body {
    position: relative;
    z-index: 1;
    padding: 0 2rem 2.25rem;
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: 2;
  }

  .news-modal__body::before {
    content: '';
    display: block;
    width: 3rem;
    height: 1px;
    margin-bottom: 1.375rem;
    background: linear-gradient(
      90deg,
      var(--color-gold-line) 0%,
      transparent 100%
    );
  }

  .news-modal__body p + p {
    margin-top: 1.125rem;
  }

  @media (max-width: 767px) {
    .modal-overlay.modal-overlay--news {
      padding: var(--space-md) var(--space-sm);
    }

    .modal-overlay.modal-overlay--news .modal.modal--news {
      max-height: min(84vh, 38rem);
      transform: translateY(0.625rem);
    }

    .modal-overlay.modal-overlay--news.is-open .modal.modal--news {
      transform: translateY(0);
    }

    .news-modal__accent {
      left: 1.25rem;
      right: 1.25rem;
    }

    .news-modal__header {
      gap: 0.5rem;
      padding: 1.5rem 1.375rem 1rem;
    }

    .news-modal__eyebrow {
      gap: 0.375rem 0.625rem;
      margin-bottom: 0.75rem;
    }

    .news-modal__title {
      margin-bottom: 0.625rem;
      font-size: var(--text-body-lg);
      letter-spacing: 0.04em;
    }

    .news-modal__date {
      font-size: 0.625rem;
      letter-spacing: 0.14em;
    }

    .news-modal__body {
      padding: 0 1.375rem 1.75rem;
      font-size: var(--text-small);
      line-height: 1.9;
    }

    .news-modal__body::before {
      width: 2.25rem;
      margin-bottom: 1.125rem;
    }

    .news-modal__body p + p {
      margin-top: 0.875rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .modal-overlay.modal-overlay--news .modal.modal--news {
      transition: opacity 0.18s ease;
      transform: none;
    }

    .modal-overlay.modal-overlay--news.is-open .modal.modal--news {
      transform: none;
    }
  }
</style>
