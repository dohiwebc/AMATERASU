---
import { resolveHref } from '@/lib/paths';

interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'outline' | 'text';
  size?: 'sm' | 'md' | 'lg';
  external?: boolean;
  class?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
} = Astro.props;

const resolvedHref = resolveHref(href);
---

<a
  href={resolvedHref}
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <slot />
</a>
