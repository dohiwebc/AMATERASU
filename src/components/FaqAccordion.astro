---
import type { Faq } from '@/types/cms';

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;
---

{faqs.length > 0 && (
  <div class="faq-accordion">
    {faqs.map((faq) => (
      <details class="faq-accordion__item">
        <summary class="faq-accordion__question">
          <span class="faq-accordion__question-text">{faq.question}</span>
          <span class="faq-accordion__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq-accordion__answer">
          <div class="faq-accordion__answer-inner">
          <p class="cms-text">{faq.answer}</p>
        </div>
        </div>
      </details>
    ))}
  </div>
)}

<script>
  import { initHeightAccordion } from '@/scripts/init-height-accordion';

  function initFaqAccordion() {
    initHeightAccordion(
      '.faq-accordion__item',
      '.faq-accordion__answer',
      '.faq-accordion__answer-inner',
    );
  }

  initFaqAccordion();
  document.addEventListener('astro:page-load', initFaqAccordion);
</script>

<style>
  .faq-accordion {
    border-top: 1px solid var(--color-border-light);
  }

  .faq-accordion__item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .faq-accordion__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.25rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
    cursor: pointer;
    list-style: none;
    transition: color var(--transition);
  }

  .faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__question::marker {
    content: '';
  }

  .faq-accordion__question:hover,
  .faq-accordion__item[open] .faq-accordion__question {
    color: var(--color-text);
  }

  .faq-accordion__question-text {
    flex: 1;
    min-width: 0;
    padding-block: 0.125rem;
    text-wrap: pretty;
  }

  .faq-accordion__icon {
    position: relative;
    flex-shrink: 0;
    width: 0.75rem;
    height: 0.75rem;
    margin-top: 0.4rem;
  }

  .faq-accordion__icon::before,
  .faq-accordion__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: var(--color-gold);
    transform: translate(-50%, -50%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-accordion__icon::before {
    width: 0.625rem;
    height: 1px;
  }

  .faq-accordion__icon::after {
    width: 1px;
    height: 0.625rem;
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .faq-accordion__item[open] .faq-accordion__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-accordion__answer {
    overflow: hidden;
    height: 0;
    transition: height 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-accordion__answer-inner {
    max-width: 52em;
    padding: 0 1.5rem 1.25rem 0;
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
  }

  .faq-accordion__answer-inner p {
    margin: 0;
  }

  @media (max-width: 767px) {
    .faq-accordion__question {
      gap: 0.875rem;
      padding: 0.875rem 0;
      font-size: 0.9375rem;
      line-height: 1.55;
    }

    .faq-accordion__question-text {
      padding-block: 0;
      text-wrap: pretty;
    }

    .faq-accordion__icon {
      width: 0.625rem;
      height: 0.625rem;
      margin-top: 0.3rem;
    }

    .faq-accordion__icon::before {
      width: 0.5rem;
    }

    .faq-accordion__icon::after {
      height: 0.5rem;
    }

    .faq-accordion__answer-inner {
      padding: 0 0.5rem 0.875rem 0;
      font-size: var(--text-small);
      line-height: 1.7;
      text-wrap: pretty;
      white-space: normal;
    }
  }

  @media (min-width: 768px) {
    .faq-accordion__question {
      padding: 1.375rem 0;
      font-size: var(--text-body-lg);
    }

    .faq-accordion__answer-inner {
      max-width: none;
      padding-bottom: 1.5rem;
      white-space: pre-line;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-accordion__answer {
      transition: none;
    }

    .faq-accordion__icon::before,
    .faq-accordion__icon::after {
      transition: none;
    }
  }
</style>
