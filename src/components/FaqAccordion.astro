---
import type { Faq } from '@/types/cms';

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;
---

{faqs.length > 0 && (
  <div class="faq-accordion">
    {faqs.map((faq) => (
      <details class="faq-accordion__item">
        <summary class="faq-accordion__question">
          <span class="faq-accordion__question-text">{faq.question}</span>
          <span class="faq-accordion__icon" aria-hidden="true"></span>
        </summary>
        <div class="faq-accordion__answer">
          <div class="faq-accordion__answer-inner">
          <p class="cms-text">{faq.answer}</p>
        </div>
        </div>
      </details>
    ))}
  </div>
)}

<script>
  function initFaqAccordion() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll<HTMLDetailsElement>('.faq-accordion__item').forEach((details) => {
      if (details.dataset.accordionInit === 'true') return;
      details.dataset.accordionInit = 'true';

      const summary = details.querySelector('summary');
      const answer = details.querySelector<HTMLElement>('.faq-accordion__answer');
      const inner = details.querySelector<HTMLElement>('.faq-accordion__answer-inner');
      if (!summary || !answer || !inner) return;

      const measureHeight = () => inner.scrollHeight;

      const finishOpen = () => {
        if (details.open) answer.style.height = 'auto';
      };

      const finishClose = () => {
        details.open = false;
        answer.style.height = '0px';
      };

      const openAnswer = () => {
        details.open = true;

        if (reducedMotion) {
          answer.style.height = 'auto';
          return;
        }

        answer.style.height = '0px';
        requestAnimationFrame(() => {
          answer.style.height = `${measureHeight()}px`;
        });

        answer.addEventListener('transitionend', function onEnd(event) {
          if (event.propertyName !== 'height') return;
          answer.removeEventListener('transitionend', onEnd);
          finishOpen();
        });
      };

      const closeAnswer = () => {
        if (reducedMotion) {
          finishClose();
          return;
        }

        answer.style.height = `${measureHeight()}px`;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            answer.style.height = '0px';
          });
        });

        answer.addEventListener('transitionend', function onEnd(event) {
          if (event.propertyName !== 'height') return;
          answer.removeEventListener('transitionend', onEnd);
          finishClose();
        });
      };

      summary.addEventListener('click', (event) => {
        event.preventDefault();
        if (details.open) {
          closeAnswer();
        } else {
          openAnswer();
        }
      });

      if (!details.open) {
        answer.style.height = '0px';
      }
    });
  }

  initFaqAccordion();
  document.addEventListener('astro:page-load', initFaqAccordion);
</script>

<style>
  .faq-accordion {
    border-top: 1px solid var(--color-border-light);
  }

  .faq-accordion__item {
    border-bottom: 1px solid var(--color-border-light);
  }

  .faq-accordion__question {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: clamp(1.5rem, 4vw, 3rem);
    padding: 1.25rem 0;
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: var(--leading-snug);
    color: var(--color-text-muted);
    cursor: pointer;
    list-style: none;
    transition: color var(--transition);
  }

  .faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__question::marker {
    content: '';
  }

  .faq-accordion__question:hover,
  .faq-accordion__item[open] .faq-accordion__question {
    color: var(--color-text);
  }

  .faq-accordion__question-text {
    flex: 1;
    padding-block: 0.125rem;
  }

  .faq-accordion__icon {
    position: relative;
    flex-shrink: 0;
    width: 0.75rem;
    height: 0.75rem;
    margin-top: 0.4rem;
  }

  .faq-accordion__icon::before,
  .faq-accordion__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    background-color: var(--color-gold);
    transform: translate(-50%, -50%);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-accordion__icon::before {
    width: 0.625rem;
    height: 1px;
  }

  .faq-accordion__icon::after {
    width: 1px;
    height: 0.625rem;
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .faq-accordion__item[open] .faq-accordion__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-accordion__answer {
    overflow: hidden;
    height: 0;
    transition: height 0.42s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .faq-accordion__answer-inner {
    max-width: 52em;
    padding: 0 1.5rem 1.25rem 0;
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
  }

  .faq-accordion__answer-inner p {
    margin: 0;
  }

  @media (min-width: 768px) {
    .faq-accordion__question {
      padding: 1.375rem 0;
      font-size: var(--text-body-lg);
    }

    .faq-accordion__answer-inner {
      padding-bottom: 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-accordion__answer {
      transition: none;
    }

    .faq-accordion__icon::before,
    .faq-accordion__icon::after {
      transition: none;
    }
  }
</style>
