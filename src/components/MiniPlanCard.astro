---
import type { Plan } from '@/types/cms';
import Button from '@/components/Button.astro';

interface Props {
  plan: Plan;
}

const { plan } = Astro.props;

const highlights =
  plan.included.length > 0 ? plan.included.slice(0, 3) : plan.recommendedFor.slice(0, 3);
const includesLabel = plan.included.length > 0 ? '含まれるもの' : 'こんな方に';
---

<div class="plan-card-outer">
  <article class="plan-card" data-plan-card>
    <h3 class="plan-card__title">{plan.title}</h3>

    <div class="plan-card__price-block">
      <p class="plan-card__price">{plan.price}</p>
      {plan.priceNote && <p class="plan-card__price-note cms-text">{plan.priceNote}</p>}
    </div>

    <p class="plan-card__desc cms-text">{plan.shortDescription}</p>

    {highlights.length > 0 && (
      <div class="plan-card__includes">
        <p class="plan-card__includes-label">{includesLabel}</p>
        <ul class="plan-card__highlights">
          {highlights.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    )}

    <p class="plan-card__period cms-text">制作期間目安：{plan.productionPeriod}</p>

    <Button href={`/mini-plans/${plan.slug}/`} variant="outline" size="md" class="btn--block">
      詳しく見る
    </Button>
  </article>
</div>
