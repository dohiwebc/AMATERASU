---
import SectionTitle from '@/components/SectionTitle.astro';

const steps = [
  {
    number: '01',
    title: 'ヒアリング',
    description: 'お店のこと、届けたい想い、ご予算などをお聞きします。オンラインでも対面でも対応できます。',
  },
  {
    number: '02',
    title: 'ご提案・お見積り',
    description: '内容に合わせたプランと構成をご提案。費用・スケジュールを分かりやすくお伝えします。',
  },
  {
    number: '03',
    title: 'デザイン制作',
    description: 'お店の雰囲気に合わせたデザインを制作。確認・修正を重ねながら進めます。',
  },
  {
    number: '04',
    title: 'コーディング・納品',
    description: 'スマホ対応のサイトをコーディングし、ファイル一式をお渡しします。',
  },
];
---

<section class="section section--white flow-section">
  <div class="container">
    <SectionTitle
      en="Flow"
      ja="制作の流れ"
      description="初めての方でも安心して進められるよう、一つひとつ丁寧にご案内します。"
      variant="editorial"
    />

    <ol class="flow">
      {steps.map((step) => (
        <li class="flow__item">
          <div class="flow__track" aria-hidden="true">
            <span class="flow__number">{step.number}</span>
            <span class="flow__line"></span>
          </div>
          <div class="flow__body">
            <h3 class="flow__title">{step.title}</h3>
            <p class="flow__desc">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .flow {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  .flow__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-md);
    padding-block: clamp(1.75rem, 4vw, 2.25rem);
    border-bottom: 1px solid var(--color-border-light);
    align-items: start;
  }

  .flow__track {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .flow__line {
    display: none;
  }

  .flow__number {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 500;
    line-height: 1;
    color: var(--color-accent);
    padding-top: 0.15rem;
    letter-spacing: 0.04em;
  }

  .flow__title {
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    font-weight: 500;
    line-height: var(--leading-tight);
    letter-spacing: 0.04em;
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }

  .flow__desc {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: 1.85;
    max-width: 36em;
  }

  @media (min-width: 768px) {
    .flow {
      max-width: 52rem;
      margin-inline: auto;
      border-top: none;
      padding-top: var(--space-xs);
    }

    .flow__item {
      grid-template-columns: 4.5rem 1fr;
      gap: clamp(1.25rem, 3vw, 2rem);
      padding-block: 0;
      padding-bottom: clamp(2rem, 4vw, 2.75rem);
      border-bottom: none;
      align-items: stretch;
    }

    .flow__item:last-child {
      padding-bottom: 0;
    }

    .flow__track {
      align-items: center;
      min-height: 100%;
    }

    .flow__line {
      display: block;
      flex: 1;
      width: 1px;
      min-height: 1.5rem;
      margin-top: 0.875rem;
      background: linear-gradient(
        180deg,
        rgba(201, 168, 110, 0.55) 0%,
        var(--color-border-light) 100%
      );
    }

    .flow__item:last-child .flow__line {
      display: none;
    }

    .flow__number {
      font-size: 1.75rem;
      padding-top: 0.125rem;
    }

    .flow__title {
      font-size: 1.1875rem;
      margin-bottom: 0.75rem;
    }

    .flow__desc {
      line-height: 1.9;
      max-width: none;
    }
  }

  @media (max-width: 767px) {
    .flow-section :global(.section-title) {
      margin-bottom: var(--space-md);
    }

    .flow-section :global(.section-title__desc) {
      font-size: var(--text-caption);
      line-height: 1.55;
      text-wrap: pretty;
    }

    .flow__item {
      grid-template-columns: 2.25rem 1fr;
      gap: 0.75rem;
      padding-block: 1rem;
    }

    .flow__number {
      font-size: 1.125rem;
      padding-top: 0.1rem;
    }

    .flow__title {
      font-size: var(--text-small);
      margin-bottom: 0.375rem;
      letter-spacing: 0.03em;
    }

    .flow__desc {
      font-size: var(--text-caption);
      line-height: 1.55;
      text-wrap: pretty;
    }
  }
</style>
