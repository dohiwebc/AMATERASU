---
import SectionTitle from '@/components/SectionTitle.astro';

const steps = [
  {
    number: '01',
    title: 'ヒアリング',
    description: 'お店のこと、届けたい想い、ご予算などをお聞きします。オンラインでも対面でも対応できます。',
  },
  {
    number: '02',
    title: 'ご提案・お見積り',
    description: '内容に合わせたプランと構成をご提案。費用・スケジュールを分かりやすくお伝えします。',
  },
  {
    number: '03',
    title: 'デザイン制作',
    description: 'お店の雰囲気に合わせたデザインを制作。確認・修正を重ねながら進めます。',
  },
  {
    number: '04',
    title: 'コーディング・納品',
    description: 'スマホ対応のサイトをコーディングし、ファイル一式をお渡しします。',
  },
];
---

<section class="section section--white flow-section">
  <div class="container">
    <SectionTitle
      en="Flow"
      ja="制作の流れ"
      description="初めての方でも安心して進められるよう、一つひとつ丁寧にご案内します。"
      variant="editorial"
    />

    <ol class="flow">
      {steps.map((step) => (
        <li class="flow__item">
          <span class="flow__number label-en">{step.number}</span>
          <h3 class="flow__title">{step.title}</h3>
          <p class="flow__desc">{step.description}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .flow {
    display: grid;
    gap: var(--space-md);
  }

  .flow__item {
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-bg-accent);
    border: 1px solid var(--color-border-light);
    display: grid;
    grid-template-columns: 44px 1fr;
    gap: 0.25rem var(--space-md);
    align-items: start;
  }

  .flow__number {
    grid-row: 1 / 3;
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--color-accent-dark);
    font-weight: 500;
    padding-top: 0.1rem;
    letter-spacing: 0.02em;
  }

  .flow__title {
    font-size: var(--text-body-lg);
    font-weight: 500;
    line-height: var(--leading-tight);
    color: var(--color-text);
  }

  .flow__desc {
    grid-column: 2;
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  @media (min-width: 768px) {
    .flow {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .flow {
      grid-template-columns: repeat(4, 1fr);
    }

    .flow__item {
      grid-template-columns: 1fr;
      padding: var(--space-lg) var(--space-md);
      gap: 0.375rem;
    }

    .flow__number {
      grid-row: auto;
      font-size: 1.25rem;
      margin-bottom: 0.25rem;
    }

    .flow__title {
      margin-bottom: 0.125rem;
    }

    .flow__desc {
      grid-column: auto;
      font-size: var(--text-small);
    }
  }
</style>
