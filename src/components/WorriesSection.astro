---
import SectionTitle from '@/components/SectionTitle.astro';

const worries = [
  {
    title: '何を載せればいいかわからない',
    description:
      '必要な情報の整理からお手伝いします。\nお店に合った構成を一緒に考えましょう。',
  },
  {
    title: '費用がどのくらいか不安',
    description:
      'プランごとに費用の目安を明示しています。\nご予算に合わせたご提案も可能です。',
  },
  {
    title: '更新や運用が難しそう',
    description:
      'シンプルで管理しやすい構成を心がけています。\n更新のサポートもご相談ください。',
  },
  {
    title: 'デザインのセンスに自信がない',
    description:
      'お店の雰囲気や写真を活かした、\n上品で伝わるデザインをご提案します。',
  },
];
---

<section class="section worries">
  <div class="container">
    <SectionTitle
      en="Concerns"
      ja="こんなお悩みはありませんか？"
      description={'ホームページ制作は初めて、という方も多くいらっしゃいます。\n一つずつ、丁寧にお答えします。'}
      variant="editorial"
    />

    <ol class="worries__list">
      {worries.map((item, i) => (
        <li class="worries__item">
          <span class="worries__index" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="worries__body">
            <h3 class="worries__title">{item.title}</h3>
            <p class="worries__desc">{item.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .worries__list {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  .worries__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-md);
    padding-block: clamp(1.75rem, 4vw, 2.25rem);
    border-bottom: 1px solid var(--color-border-light);
    align-items: start;
  }

  .worries__index {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 500;
    line-height: 1;
    color: var(--color-accent);
    padding-top: 0.15rem;
    letter-spacing: 0.04em;
  }

  .worries__title {
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 2vw, 1.1875rem);
    font-weight: 500;
    line-height: var(--leading-tight);
    letter-spacing: 0.04em;
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }

  .worries__desc {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: 1.85;
    max-width: 36em;
    white-space: pre-line;
  }

  @media (min-width: 768px) {
    .worries :global(.section-title__desc) {
      white-space: pre-line;
    }

    .worries__list {
      grid-template-columns: repeat(2, 1fr);
      column-gap: var(--space-xl);
      border-top: none;
    }

    .worries__item {
      grid-template-columns: 3rem 1fr;
      padding-inline: 0;
      border-bottom: none;
      border-top: 1px solid var(--color-border-light);
    }

    .worries__item:nth-child(odd) {
      padding-right: var(--space-lg);
      border-right: 1px solid var(--color-border-light);
    }

    .worries__item:nth-child(even) {
      padding-left: var(--space-lg);
    }
  }

  @media (max-width: 767px) {
    .worries :global(.section-title) {
      margin-bottom: var(--space-md);
    }

    .worries :global(.section-title__desc) {
      font-size: var(--text-caption);
      line-height: 1.55;
      text-wrap: pretty;
      white-space: normal;
    }

    .worries__item {
      grid-template-columns: 2.25rem 1fr;
      gap: 0.75rem;
      padding-block: 1rem;
    }

    .worries__index {
      font-size: 1.125rem;
      padding-top: 0.1rem;
    }

    .worries__title {
      font-size: var(--text-small);
      margin-bottom: 0.375rem;
      letter-spacing: 0.03em;
    }

    .worries__desc {
      font-size: var(--text-caption);
      line-height: 1.55;
      text-wrap: pretty;
    }
  }
</style>
