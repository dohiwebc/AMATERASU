---
import Layout from '@/layouts/Layout.astro';
import WorkDetail from '@/components/WorkDetail.astro';
import CTASection from '@/components/CTASection.astro';
import { getPlans, getSiteSettings, getWorks } from '@/lib/microcms';
import { toMetaDescription } from '@/lib/text';
import { buildWorkPlansMap, type WorkRelatedPlan } from '@/lib/works';
import type { Work } from '@/types/cms';

export async function getStaticPaths() {
  const [works, plans] = await Promise.all([getWorks(), getPlans()]);
  const workPlansMap = buildWorkPlansMap(plans);

  return works.map((work) => ({
    params: { slug: work.slug },
    props: {
      work,
      relatedPlans: workPlansMap.get(work.id) ?? [],
    },
  }));
}

interface Props {
  work: Work;
  relatedPlans: WorkRelatedPlan[];
}

const { work, relatedPlans } = Astro.props;
const settings = await getSiteSettings();
const pageDescription = toMetaDescription(work.shortDescription, work.description);
---

<Layout
  title={`制作実績 | ${work.title}`}
  description={pageDescription}
  ogImage={work.thumbnail}
  settings={settings}
>
  <div class="page-header page-header--compact">
    <div class="container container--wide">
      <div class="page-header__inner page-header__inner--wide">
        <p class="page-header__label label-en">Works</p>
      </div>
    </div>
  </div>

  <section class="section section--after-header section--white work-detail-page">
    <div class="container container--wide">
      <WorkDetail work={work} relatedPlans={relatedPlans} />
    </div>
  </section>

  <CTASection settings={settings} />
</Layout>

<style>
  @media (max-width: 767px) {
    .page-header--compact {
      padding-block: var(--space-sm) var(--space-xs);
    }

    .work-detail-page {
      padding-top: var(--space-md);
      padding-bottom: var(--space-xl);
    }
  }
</style>
