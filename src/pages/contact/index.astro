---
import Layout from '@/layouts/Layout.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import ContactForm from '@/components/ContactForm.astro';
import NotifyOnlyForm from '@/components/NotifyOnlyForm.astro';
import CTASection from '@/components/CTASection.astro';
import FaqSection from '@/components/FaqSection.astro';
import Button from '@/components/Button.astro';
import { getContactSettings, getSiteSettings } from '@/lib/microcms';
import { getAcceptanceStatus } from '@/lib/acceptance-status';
import { ACCEPTANCE_STATUS } from '@/types/cms';
import { getInstagramHandle, getXHandle, hasSocialUrl } from '@/lib/text';

const [settings, contact] = await Promise.all([
  getSiteSettings(),
  getContactSettings(),
]);

const acceptance = getAcceptanceStatus(settings, contact);
const isOpen = acceptance.status === ACCEPTANCE_STATUS.OPEN;

const instagramHandle = getInstagramHandle(settings.instagramUrl);
const xHandle = getXHandle(settings.xUrl);
const xNote = contact.xDescription?.trim();

const consultationTips = [
  'お店やサービスの概要',
  '掲載したい文章',
  '写真やロゴ',
  'メニューや料金表',
  'SNSリンク',
  '参考にしたいサイト',
  '希望納期',
  '予算の目安',
];
---

<Layout
  title={contact.title}
  description={contact.description}
  settings={settings}
>
  <div class="page-header">
    <div class="container">
      <div class="page-header__inner">
        <p class="page-header__label label-en">Contact</p>
        <h1 class="page-header__title">{contact.title}</h1>
        <p class="page-header__desc cms-text">{contact.description}</p>
      </div>
    </div>
  </div>

  <section class="section section--after-header">
    <div class="container">
      {isOpen ? (
        <div class="contact-reassure">
          <p class="contact-reassure__lead">
            <span>ご相談は無料です。</span>
            <span>しつこい営業は一切ありません。</span>
          </p>
          <p class="contact-reassure__reply cms-text">{contact.replyTime}</p>
        </div>
      ) : (
        <div class="contact-closed" role="status">
          <p class="contact-closed__label label-en">Status</p>
          <h2 class="contact-closed__title">{acceptance.pageTitle}</h2>
          <p class="contact-closed__lead cms-text">{acceptance.leadText}</p>
          <p class="contact-closed__reply cms-text">{acceptance.replyText}</p>
        </div>
      )}

      <div class="contact-layout">
        <div class="contact-layout__form">
          {acceptance.formMode === 'full' && (
            <>
              <p class="contact-form-section__desc cms-text">{acceptance.formDescription}</p>
              <ContactForm contact={contact} />
            </>
          )}
          {acceptance.formMode === 'notify' && (
            <>
              <p class="contact-form-section__desc cms-text">{acceptance.formDescription}</p>
              <NotifyOnlyForm contact={contact} replyText={acceptance.replyText} />
            </>
          )}
          {acceptance.formMode === 'none' && (
            <p class="contact-form-section__desc contact-form-section__desc--closed cms-text">
              {'現在はフォームからのお問い合わせをお受けしておりません。\n再開の際はお知らせにてご案内いたします。'}
            </p>
          )}
        </div>

        <aside class="contact-layout__aside">
          <div class="contact-studio">
            <p class="contact-studio__label label-en">Studio</p>
            <h2 class="contact-studio__title">制作している人</h2>
            <div class="contact-studio__body">
              <p>
                AMATERASU Web Studioは、愛媛・松山を拠点に、個人店・小規模事業者向けのWeb制作を行っています。
              </p>
              <p>
                初めてホームページを作る方にも分かりやすく、必要な情報の整理からデザイン・制作まで丁寧に対応します。
              </p>
            </div>
          </div>

          <div class="contact-alt">
            <p class="contact-alt__label label-en">Other ways</p>
            <div class="contact-alt__list">
              <div class="contact-alt__item">
                <h3 class="contact-alt__title">メール</h3>
                <a href={`mailto:${settings.email}`} class="contact-alt__link">{settings.email}</a>
                {contact.emailDescription && (
                  <p class="contact-alt__desc cms-text">{contact.emailDescription}</p>
                )}
              </div>
              {hasSocialUrl(settings.instagramUrl) && instagramHandle && (
                <div class="contact-alt__item">
                  <h3 class="contact-alt__title">Instagram</h3>
                  <a
                    href={settings.instagramUrl}
                    class="contact-alt__link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {instagramHandle}
                  </a>
                </div>
              )}
              {hasSocialUrl(settings.xUrl) && xHandle && (
                <div class="contact-alt__item">
                  <h3 class="contact-alt__title">X（旧Twitter）</h3>
                  <a
                    href={settings.xUrl}
                    class="contact-alt__link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {xHandle}
                  </a>
                  {xNote && (
                    <p class="contact-alt__desc contact-alt__desc--note cms-text">{xNote}</p>
                  )}
                </div>
              )}
            </div>
          </div>

          <div class="contact-note">
            <SectionTitle en="Tips" ja="ご相談前にあるとスムーズなもの" variant="minimal" />
            <ul class="list-check">
              {consultationTips.map((tip) => (
                <li>{tip}</li>
              ))}
            </ul>
            <p class="contact-options-hint">
              <Button href="/options/" variant="outline" size="sm">
                公開作業や保守などのオプションも相談できます
              </Button>
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <FaqSection
    description="お問い合わせ前にご確認いただきたい内容です。"
    categories={['contact', 'price', 'other']}
    groupByCategory
    sectionClass="section--warm"
  />

  <CTASection settings={settings} />
</Layout>

<style>
  .contact-reassure {
    padding: var(--space-md) var(--space-lg);
    background-color: var(--color-bg-accent);
    border: 1px solid var(--color-accent-light);
    margin-bottom: var(--space-lg);
  }

  .contact-reassure__lead {
    font-size: var(--text-body-lg);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 0.375rem;
  }

  .contact-reassure__reply {
    font-size: var(--text-body);
    color: var(--color-text-muted);
  }

  .contact-closed {
    padding: clamp(2rem, 5vw, 3rem) var(--space-lg);
    margin-bottom: var(--space-lg);
    text-align: center;
    background-color: var(--color-status-closed-bg);
    border: 1px solid var(--color-status-closed-border);
  }

  .contact-closed__label {
    margin-bottom: 0.75rem;
    color: var(--color-status-closed);
  }

  .contact-closed__title {
    margin: 0 0 1rem;
    font-family: var(--font-serif);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 500;
    letter-spacing: 0.08em;
    line-height: var(--leading-tight);
    color: var(--color-status-closed);
  }

  .contact-closed__lead {
    max-width: 40rem;
    margin: 0 auto 0.875rem;
    font-size: var(--text-body-lg);
    font-weight: 500;
    color: var(--color-text);
    line-height: var(--leading-snug);
    text-wrap: pretty;
  }

  .contact-closed__reply {
    max-width: 40rem;
    margin: 0 auto;
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .contact-form-section__desc--closed {
    padding: var(--space-md);
    background-color: var(--color-bg-accent);
    border: 1px solid var(--color-border-light);
  }

  @media (min-width: 768px) {
    .contact-closed__lead,
    .contact-closed__reply,
    .contact-form-section__desc,
    .contact-form-section__desc--closed {
      white-space: pre-line;
    }
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 26rem);
      gap: clamp(2rem, 4vw, 3.5rem);
    }

    .contact-layout__aside {
      position: sticky;
      top: calc(var(--header-height) + 1.5rem);
      padding-left: clamp(1.5rem, 3vw, 2rem);
      border-left: 1px solid var(--color-border-light);
    }

    .contact-closed__lead,
    .contact-closed__reply {
      max-width: 44rem;
    }

    .contact-reassure__lead {
      text-wrap: pretty;
    }
  }

  .contact-form-section__desc {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    margin-bottom: var(--space-md);
  }

  .contact-layout__aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .contact-studio__label {
    margin-bottom: 0.375rem;
    color: var(--color-text-light);
  }

  .contact-studio__title {
    font-family: var(--font-serif);
    font-size: var(--text-body-lg);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }

  .contact-studio__body {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  .contact-studio__body p {
    margin: 0;
  }

  .contact-alt__label {
    margin-bottom: var(--space-sm);
  }

  .contact-alt__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-alt__title {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--color-text-light);
    letter-spacing: 0.06em;
    margin-bottom: 0.375rem;
  }

  .contact-alt__link {
    font-size: var(--text-body);
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.125rem;
    transition: color var(--transition), border-color var(--transition);
  }

  .contact-alt__link:hover {
    color: var(--color-text);
    border-bottom-color: var(--color-text);
  }

  .contact-alt__desc {
    margin-top: 0.5rem;
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
  }

  .contact-alt__desc--note {
    font-size: 0.6875rem;
    color: var(--color-text-light);
  }

  .contact-note {
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
    margin-bottom: 0;
  }

  .contact-options-hint {
    margin: var(--space-md) 0 0;
  }

  .contact-options-hint :global(.btn) {
    white-space: normal;
    height: auto;
    line-height: 1.5;
    text-align: center;
    font-size: var(--text-caption);
    letter-spacing: 0.06em;
    padding: 0.5rem 1rem;
  }

  @media (max-width: 767px) {
    :global(.page-header) {
      padding-block: var(--space-md) var(--space-sm);
    }

    :global(.page-header__label) {
      margin-bottom: 0.375rem;
    }

    :global(.page-header__title) {
      font-size: clamp(1.5rem, 6vw, 1.75rem);
      margin-bottom: 0.5rem;
    }

    :global(.page-header__desc) {
      font-size: var(--text-small);
      line-height: 1.55;
      text-wrap: pretty;
    }

    :global(.section.section--after-header) {
      padding-top: var(--space-md);
    }

    :global(.faq-section.section) {
      padding-block: var(--space-xl);
    }

    .contact-reassure {
      padding: var(--space-sm) var(--space-md);
      margin-bottom: var(--space-md);
    }

    .contact-reassure__lead {
      font-size: var(--text-body);
      margin-bottom: 0.25rem;
    }

    .contact-reassure__lead span {
      display: block;
    }

    .contact-reassure__reply {
      font-size: var(--text-small);
      line-height: 1.55;
    }

    .contact-closed {
      padding: 1rem 1rem 1.125rem;
      margin-bottom: var(--space-md);
      text-align: left;
    }

    .contact-closed__label {
      margin-bottom: 0.25rem;
      font-size: 0.625rem;
      letter-spacing: 0.14em;
    }

    .contact-closed__title {
      margin-bottom: 0.5rem;
      font-size: 1.125rem;
      letter-spacing: 0.04em;
      line-height: 1.35;
    }

    .contact-closed__lead {
      font-size: var(--text-caption);
      font-weight: 500;
      line-height: 1.55;
      margin-bottom: 0.5rem;
      white-space: normal;
      text-wrap: pretty;
    }

    .contact-closed__reply {
      padding-top: 0.5rem;
      border-top: 1px solid color-mix(in srgb, var(--color-status-closed-border) 70%, transparent);
      font-size: var(--text-caption);
      line-height: 1.55;
      white-space: normal;
      text-wrap: pretty;
    }

    .contact-form-section__desc--closed {
      padding: var(--space-sm) var(--space-md);
      font-size: var(--text-small);
      line-height: 1.55;
      white-space: normal;
    }

    .contact-layout {
      gap: var(--space-lg);
    }

    .contact-form-section__desc {
      font-size: var(--text-small);
      line-height: 1.55;
      margin-bottom: var(--space-sm);
      white-space: normal;
    }

    .contact-layout__aside {
      gap: var(--space-md);
    }

    .contact-studio__title {
      font-size: var(--text-body);
      margin-bottom: 0.5rem;
    }

    .contact-studio__body {
      font-size: var(--text-caption);
      line-height: 1.55;
      gap: 0.5rem;
    }

    .contact-alt__label {
      margin-bottom: 0.375rem;
    }

    .contact-alt__list {
      gap: var(--space-sm);
    }

    .contact-alt__title {
      font-size: var(--text-caption);
      margin-bottom: 0.25rem;
    }

    .contact-alt__link {
      font-size: var(--text-small);
    }

    .contact-alt__desc {
      margin-top: 0.375rem;
      font-size: var(--text-caption);
      line-height: 1.5;
    }

    .contact-note {
      padding-top: var(--space-sm);
    }

    .contact-options-hint {
      margin-top: var(--space-sm);
    }

    .contact-options-hint :global(.btn) {
      width: 100%;
    }

    .contact-note :global(.section-title) {
      margin-bottom: var(--space-sm);
    }

    .contact-note :global(.list-check) {
      gap: 0.5rem;
    }

    .contact-note :global(.list-check li) {
      font-size: var(--text-small);
      line-height: 1.65;
      text-wrap: pretty;
    }
  }
</style>
