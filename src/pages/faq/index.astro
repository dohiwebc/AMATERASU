---
import Layout from '@/layouts/Layout.astro';
import FaqSection from '@/components/FaqSection.astro';
import CTASection from '@/components/CTASection.astro';
import Button from '@/components/Button.astro';
import { getSiteSettings } from '@/lib/microcms';
import { FAQ_CATEGORY_ORDER } from '@/types/cms';

const settings = await getSiteSettings();
---

<Layout
  title="よくあるご質問"
  description="AMATERASU Web Studioの制作プラン、料金、納期、お問い合わせに関するよくあるご質問。"
  settings={settings}
>
  <div class="page-header">
    <div class="container">
      <div class="page-header__inner">
        <p class="page-header__label label-en">FAQ</p>
        <h1 class="page-header__title">よくあるご質問</h1>
        <p class="page-header__desc">
          制作プランや料金、納期、お問い合わせについて、よくいただくご質問をまとめました。
        </p>
      </div>
    </div>
  </div>

  <FaqSection
    en="Questions"
    ja="カテゴリ別のご質問"
    description="気になる項目をタップして、回答をご確認ください。"
    categories={FAQ_CATEGORY_ORDER}
    groupByCategory
    sectionClass="section--after-header section--white"
  />

  <div class="faq-options-link">
    <div class="container">
      <p class="faq-options-link__text">
        公開作業・保守・CMS追加などの料金は、オプションページでもご確認いただけます。
      </p>
      <Button href="/options/" variant="outline" size="lg">
        詳しいオプション料金を見る
      </Button>
    </div>
  </div>

  <CTASection settings={settings} />
</Layout>

<style>
  .faq-options-link {
    padding: 0 0 var(--space-xl);
    background-color: var(--color-bg-white);
  }

  .faq-options-link__text {
    margin: 0 0 1rem;
    font-size: var(--text-small);
    color: var(--color-text-muted);
    line-height: var(--leading-body);
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .faq-options-link__text {
      font-size: var(--text-body);
      max-width: 42rem;
    }
  }

  @media (max-width: 767px) {
    .faq-options-link {
      padding-bottom: var(--space-lg);
    }

    .faq-options-link__text {
      font-size: var(--text-caption);
      line-height: 1.65;
      margin-bottom: 0.875rem;
    }

    .faq-options-link :global(.btn) {
      width: 100%;
      text-align: center;
      white-space: normal;
      height: auto;
      line-height: 1.5;
    }
  }
</style>
