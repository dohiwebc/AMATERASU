---
import Layout from '@/layouts/Layout.astro';
import NewsList from '@/components/NewsList.astro';
import NewsModal from '@/components/NewsModal.astro';
import CTASection from '@/components/CTASection.astro';
import { getNews, getSiteSettings } from '@/lib/microcms';

const [settings, news] = await Promise.all([getSiteSettings(), getNews()]);
---

<Layout
  title="お知らせ"
  description="AMATERASU Web Studioからのお知らせ一覧です。"
  settings={settings}
>
  <div class="page-header">
    <div class="container">
      <div class="page-header__inner">
        <p class="page-header__label label-en">News</p>
        <h1 class="page-header__title">お知らせ</h1>
        <p class="page-header__desc">
          スタジオからのお知らせや更新情報を掲載しています。
        </p>
      </div>
    </div>
  </div>

  <section class="section section--after-header section--white">
    <div class="container">
      <NewsList items={news} compact />
    </div>
  </section>

  <NewsModal items={news} />

  <CTASection settings={settings} />
</Layout>

<style>
  @media (max-width: 767px) {
    :global(.page-header) {
      padding-block: var(--space-md) var(--space-sm);
    }

    :global(.page-header__label) {
      margin-bottom: 0.375rem;
    }

    :global(.page-header__title) {
      font-size: clamp(1.5rem, 6vw, 1.75rem);
      margin-bottom: 0.5rem;
    }

    :global(.page-header__desc) {
      font-size: var(--text-small);
      line-height: 1.55;
      text-wrap: pretty;
    }

    :global(.section.section--after-header) {
      padding-top: var(--space-md);
      padding-bottom: var(--space-xl);
    }
  }
</style>
