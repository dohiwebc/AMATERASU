---
import '@/styles/global.css';
import Header from '@/components/Header.astro';
import AcceptanceStatusSection from '@/components/AcceptanceStatusSection.astro';
import Footer from '@/components/Footer.astro';
import PageReveal from '@/components/PageReveal.astro';
import type { SiteSettings } from '@/types/cms';
import { withBase } from '@/lib/paths';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  settings: SiteSettings;
}

const { title, description, ogImage, settings } = Astro.props;
const pageTitle = title ? `${title} | ${settings.brandDisplay}` : settings.seoTitle;
const pageDescription = description ?? settings.seoDescription;
const ogImageUrl = ogImage ?? settings.ogImage;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : undefined;
/**
 * favicon は未キャッシュのパスを優先する。
 * `/` と `/works/` などはブラウザが古いアイコンを強く保持しやすい。
 */
const icon32 = withBase('/icons/amaterasu-32.png');
const icon16 = withBase('/icons/amaterasu-16.png');
const iconIco = withBase('/icons/amaterasu.ico');
const iconApple = withBase('/icons/amaterasu-apple-touch.png');
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDescription} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta name="twitter:card" content="summary_large_image" />}
    {/* PNG を先に指定（Chrome 等が優先しやすい） */}
    <link rel="icon" type="image/png" sizes="32x32" href={icon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={icon16} />
    <link rel="icon" href={iconIco} sizes="any" />
    <link rel="shortcut icon" href={iconIco} />
    {/* ルートの /favicon.ico 自動取得にも対応 */}
    <link rel="icon" href={withBase('/favicon.ico')} sizes="48x48" />
    <link rel="apple-touch-icon" sizes="180x180" href={iconApple} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Header settings={settings} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <AcceptanceStatusSection settings={settings} />
    <Footer settings={settings} />
    <PageReveal />
  </body>
</html>

<style is:global>
  main {
    min-height: calc(100vh - var(--header-height) - 240px);
  }
</style>
